        )}

        {studentServicesSubTab === 'digital-id' && (
          <div className="space-y-4">
            <div className="bg-gradient-to-r from-pink-50 to-pink-100 p-4 rounded-lg border border-pink-300">
              <h3 className="font-bold text-slate-900 mb-1">🆔 Virtual Campus ID</h3>
              <p className="text-sm text-slate-700">Digital QR code for gate access & campus facilities</p>
            </div>

            {/* Virtual ID Card */}
            <div className="flex justify-center py-4">
              <div className="bg-gradient-to-br from-slate-900 to-slate-800 p-6 rounded-lg shadow-2xl max-w-sm w-full border-4 border-yellow-500">
                {/* ID Card Header */}
                <div className="text-white mb-4 border-b border-slate-700 pb-3">
                  <p className="text-xs text-slate-400 uppercase tracking-wider">Seku University</p>
                  <h3 className="text-xl font-bold">Campus ID Card</h3>
                </div>

                {/* Student Info */}
                <div className="text-white mb-4 space-y-2">
                  <div className="flex justify-between text-sm">
                    <span className="text-slate-400">Name:</span>
                    <span className="font-semibold">{studentData.name}</span>
                  </div>
                  <div className="flex justify-between text-sm">
                    <span className="text-slate-400">Reg No:</span>
                    <span className="font-semibold font-mono">{studentData.regNo}</span>
                  </div>
                  <div className="flex justify-between text-sm">
                    <span className="text-slate-400">Room:</span>
                    <span className="font-semibold">{studentData.room}</span>
                  </div>
                </div>

                {/* QR Code Mock */}
                <div className="bg-white p-3 rounded-lg mb-4 flex items-center justify-center">
                  <svg className="w-32 h-32" viewBox="0 0 200 200" fill="currentColor">
                    {/* Simple QR pattern */}
                    <rect width="200" height="200" fill="white"/>
                    <rect x="10" y="10" width="50" height="50" fill="black"/>
                    <rect x="20" y="20" width="30" height="30" fill="white"/>
                    <rect x="25" y="25" width="20" height="20" fill="black"/>
                    <rect x="140" y="10" width="50" height="50" fill="black"/>
                    <rect x="150" y="20" width="30" height="30" fill="white"/>
                    <rect x="155" y="25" width="20" height="20" fill="black"/>
                    <rect x="10" y="140" width="50" height="50" fill="black"/>
                    <rect x="20" y="150" width="30" height="30" fill="white"/>
                    <rect x="25" y="155" width="20" height="20" fill="black"/>
                    {/* Center pattern */}
                    <circle cx="100" cy="100" r="30" fill="black"/>
                    <circle cx="100" cy="100" r="20" fill="white"/>
                    <circle cx="100" cy="100" r="10" fill="black"/>
                  </svg>
                </div>

                {/* Valid Info */}
                <div className="text-white text-center text-xs border-t border-slate-700 pt-3">
                  <p className="text-slate-400">Valid for gate access & facilities</p>
                  <p className="text-yellow-500 font-bold mt-1">Expires: Dec 2026</p>
                </div>
              </div>
            </div>

            {/* ID Features */}
            <div className="p-4 bg-slate-100 rounded-lg">
              <h4 className="font-bold text-slate-900 mb-3">✨ Features</h4>
              <ul className="text-sm text-slate-700 space-y-2">
                <li>✓ Show QR at main gate for entry</li>
                <li>✓ Access hostel facilities 24/7</li>
                <li>✓ Use at library check-in</li>
                <li>✓ Required for exam attendance</li>
                <li>✓ Valid year-round while enrolled</li>
                <li>✓ Screenshot & save for offline use</li>
              </ul>
            </div>
          </div>
        )}
      </div>
    </div>
  );

  // ============= RENDER: GRADUATION AUDIT TAB =============
  const renderGraduationAuditTab = () => (
    <div className="flex flex-col h-full">
      {/* Header */}
      <div className="bg-gradient-to-r from-purple-50 to-purple-100 p-4 border-b border-purple-200">
        <h2 className="text-xl font-bold text-slate-900">✅ Graduation Audit Checklist</h2>
        <p className="text-sm text-slate-700 mt-1">Complete all items before graduation application</p>
      </div>

      {/* Progress Bar */}
      <div className="p-4 bg-white border-b border-slate-200">
        <div className="flex justify-between items-center mb-2">
          <span className="text-sm font-semibold text-slate-900">Progress</span>
          <span className="text-sm font-bold text-purple-600">{getGraduationProgress()}%</span>
        </div>
        <div className="w-full bg-slate-200 rounded-full h-3">
          <div
            className="h-3 rounded-full bg-gradient-to-r from-purple-500 to-purple-600 transition-all"
            style={{ width: `${getGraduationProgress()}%` }}
          />
        </div>
      </div>

      {/* Checklist Items */}
      <div className="flex-1 overflow-y-auto p-4 space-y-3">
        {graduationChecklist.map(item => (
          <div
            key={item.id}
            onClick={() => toggleChecklistItem(item.id)}
            className={`p-4 rounded-lg border-2 cursor-pointer transition transform hover:scale-105 ${
              item.completed
                ? 'bg-green-50 border-green-500'
                : 'bg-slate-50 border-slate-300 hover:border-purple-300'
            }`}
          >
            <div className="flex items-center gap-3">
              <div
                className={`w-6 h-6 rounded-full border-2 flex items-center justify-center flex-shrink-0 ${
                  item.completed
                    ? 'bg-green-500 border-green-500'
                    : 'border-slate-400 group-hover:border-purple-500'
                }`}
              >
                {item.completed && <CheckIcon />}
              </div>
              <div className="flex-1">
                <p
                  className={`font-semibold ${
                    item.completed
                      ? 'text-green-700 line-through'
                      : 'text-slate-900'
                  }`}
                >
                  {item.item}
                </p>
              </div>
              {item.completed && <span className="text-2xl">✓</span>}
            </div>
          </div>
        ))}
      </div>

      {/* Summary */}
      <div className="p-4 bg-slate-50 border-t border-slate-200">
        <div className="grid grid-cols-3 gap-2 text-center">
          <div className="bg-white rounded p-2">
            <p className="text-2xl font-bold text-green-600">{graduationChecklist.filter(i => i.completed).length}</p>
            <p className="text-xs text-slate-600">Completed</p>
          </div>
          <div className="bg-white rounded p-2">
            <p className="text-2xl font-bold text-amber-600">{graduationChecklist.filter(i => !i.completed).length}</p>
            <p className="text-xs text-slate-600">Remaining</p>
          </div>
          <div className="bg-white rounded p-2">
            <p className="text-2xl font-bold text-blue-600">{graduationChecklist.length}</p>
            <p className="text-xs text-slate-600">Total Items</p>
          </div>
        </div>
      </div>
    </div>
  );

  // ============= RENDER: CAREER BRIDGE TAB =============
  const renderCareerBridgeTab = () => (
    <div className="flex flex-col h-full">
      {/* Header */}
      <div className="bg-gradient-to-r from-blue-50 to-blue-100 p-4 border-b border-blue-200">
        <h2 className="text-xl font-bold text-slate-900">💼 Career Bridge & Logbook</h2>
        <p className="text-sm text-slate-700 mt-1">NITA Attachments, Engineering & Business Logbooks</p>
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto p-4 space-y-4">
        {/* Logbook Assistant Info */}
        <div className="bg-blue-50 p-4 rounded-lg border border-blue-200">
          <h3 className="font-bold text-slate-900 mb-2">📝 AI Logbook Assistant</h3>
          <p className="text-sm text-slate-700 mb-3">Get professional writing assistance for your attachment logbooks</p>
          <p className="text-xs text-slate-600 italic">Supports: NITA Attachments, Engineering Projects, Business Internships</p>
        </div>

        {/* Logbook Entry Input */}
        <div className="space-y-2">
          <label className="block text-sm font-semibold text-slate-900">Your Logbook Entry</label>
          <textarea
            value={logbookEntry}
            onChange={(e) => setLogbookEntry(e.target.value)}
            placeholder="Date: [Date]&#10;Tasks: [What did you do?]&#10;Skills: [What did you learn?]&#10;Challenges: [What was difficult?]"
            className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm font-mono"
            rows="6"
          />
        </div>

        {/* Submit Button */}
        <button
          onClick={handleLogbookAssist}
          className="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white py-3 rounded-lg font-bold transition transform hover:scale-105"
        >
          ✨ Get AI Writing Assistance
        </button>

        {/* AI Response */}
        {logbookAIResponse && (
          <div className="p-4 bg-gradient-to-r from-green-50 to-emerald-50 border border-green-300 rounded-lg space-y-4">
            <div>
              <p className="text-sm font-bold text-green-900 mb-2">📝 Your Entry:</p>
              <div className="bg-white p-3 rounded border-l-4 border-green-500 text-sm text-slate-700">
                {logbookAIResponse.originalEntry}
              </div>
            </div>
            <div className="bg-white p-3 rounded border-l-4 border-blue-500">
              <p className="text-sm font-bold text-blue-900 mb-2">✨ Professional Version:</p>
              <p className="text-sm text-slate-700">{logbookAIResponse.improvedVersion}</p>
            </div>
            <div className="bg-white p-3 rounded border-l-4 border-amber-500">
              <p className="text-sm font-bold text-amber-900 mb-2">💡 Feedback & Tips:</p>
              <p className="text-sm text-slate-700">{logbookAIResponse.feedback}</p>
            </div>
          </div>
        )}

        {/* Career Resources */}
        <div className="p-4 bg-slate-50 rounded-lg border border-slate-200">
          <h4 className="font-bold text-slate-900 mb-3">📚 Career Resources</h4>
          <ul className="text-sm text-slate-700 space-y-2">
            <li className="flex gap-2">
              <span>🎯</span>
              <span><strong>NITA Competencies:</strong> Technical skills, Soft skills, Professional conduct</span>
            </li>
            <li className="flex gap-2">
              <span>📊</span>
              <span><strong>Engineering Requirements:</strong> Technical drawings, Project reports, Analysis</span>
            </li>
            <li className="flex gap-2">
              <span>💼</span>
              <span><strong>Business Logs:</strong> Market analysis, Financial planning, Leadership experience</span>
            </li>
            <li className="flex gap-2">
              <span>✍️</span>
              <span><strong>Writing Standards:</strong> Professional tone, Clear structure, Evidence-based</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  );

  // ============= RENDER: ADMIN DASHBOARD =============
  const renderAdminDashboard = () => (
    <div className="flex flex-col h-full pb-20 bg-gradient-to-br from-slate-900 to-slate-800">
      {/* Header */}
      <div className="bg-slate-950 border-b border-slate-700 p-4 shadow-lg">
        <div className="flex justify-between items-center">
          <div>
            <h1 className="text-2xl font-bold text-white">🔐 Executive Intelligence Dashboard</h1>
            <p className="text-xs text-slate-400">Vice-Chancellor Analytics & Insights</p>
          </div>
          <button
            onClick={handleAdminLogout}
            className="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-semibold text-sm"
          >
            Logout
          </button>
        </div>
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto p-4 space-y-6">
        {/* Hostel Health */}
        <div className="bg-slate-800 rounded-lg p-6 border border-slate-700 shadow-xl">
          <h2 className="text-xl font-bold text-white mb-4">🏠 Hostel Facilities Health</h2>
          <div className="space-y-3">
            {analyticsData.hostelRepairs.map((hostel, i) => (
              <div key={i} className="flex items-center justify-between p-3 bg-slate-700 rounded-lg">
                <div className="flex-1">
                  <p className="font-semibold text-white">{hostel.hostel} Hall</p>
                  <p className="text-sm text-slate-300">{hostel.tickets} repair tickets</p>
                </div>
                <div className="flex gap-4 items-center">
                  <div className="w-24 bg-slate-600 rounded-full h-2">
                    <div
                      className={`h-2 rounded-full ${hostel.tickets > 10 ? 'bg-red-500' : hostel.tickets > 5 ? 'bg-yellow-500' : 'bg-green-500'}`}
                      style={{ width: `${Math.min(hostel.tickets * 8, 100)}%` }}
                    />
                  </div>
                  <span className="text-sm font-bold w-16">{hostel.status}</span>
                </div>
              </div>
            ))}
          </div>
          <div className="mt-4 p-3 bg-red-900 rounded-lg border border-red-700">
            <p className="text-red-100 text-sm">
              <span className="font-bold">⚠️ CRITICAL:</span> Turkana Hall showing 15 tickets - recommend immediate maintenance audit
            </p>
          </div>
        </div>

        {/* Student Sentiment */}
        <div className="bg-slate-800 rounded-lg p-6 border border-slate-700 shadow-xl">
          <h2 className="text-xl font-bold text-white mb-4">💭 Student Wellness Pulse</h2>
          <div className="grid grid-cols-3 gap-4">
            <div className="bg-slate-700 rounded-lg p-4 text-center">
              <p className="text-slate-400 text-sm mb-2">Stress Level</p>
              <div className="relative w-24 h-24 mx-auto">
                <svg className="w-24 h-24" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="45" fill="none" stroke="#334155" strokeWidth="8" />
                  <circle
                    cx="50"
                    cy="50"
                    r="45"
                    fill="none"
                    stroke="#ef4444"
                    strokeWidth="8"
                    strokeDasharray={`${analyticsData.studentSentiment.stress * 2.83} 283`}
                    transform="rotate(-90 50 50)"
                  />
                </svg>
                <span className="absolute inset-0 flex items-center justify-center text-2xl font-bold text-red-500">
                  {analyticsData.studentSentiment.stress}%
                </span>
              </div>
            </div>
            <div className="bg-slate-700 rounded-lg p-4 text-center">
              <p className="text-slate-400 text-sm mb-2">Anxiety Index</p>
              <div className="relative w-24 h-24 mx-auto">
                <svg className="w-24 h-24" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="45" fill="none" stroke="#334155" strokeWidth="8" />
                  <circle
                    cx="50"
                    cy="50"
                    r="45"
                    fill="none"
                    stroke="#f59e0b"
                    strokeWidth="8"
                    strokeDasharray={`${analyticsData.studentSentiment.anxiety * 2.83} 283`}
                    transform="rotate(-90 50 50)"
                  />
                </svg>
                <span className="absolute inset-0 flex items-center justify-center text-2xl font-bold text-amber-500">
                  {analyticsData.studentSentiment.anxiety}%
                </span>
              </div>
            </div>
            <div className="bg-slate-700 rounded-lg p-4 text-center">
              <p className="text-slate-400 text-sm mb-2">Happiness Index</p>
              <div className="relative w-24 h-24 mx-auto">
                <svg className="w-24 h-24" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="45" fill="none" stroke="#334155" strokeWidth="8" />
                  <circle
                    cx="50"
                    cy="50"
                    r="45"
                    fill="none"
                    stroke="#10b981"
                    strokeWidth="8"
                    strokeDasharray={`${analyticsData.studentSentiment.happiness * 2.83} 283`}
                    transform="rotate(-90 50 50)"
                  />
                </svg>
                <span className="absolute inset-0 flex items-center justify-center text-2xl font-bold text-green-500">
                  {analyticsData.studentSentiment.happiness}%
                </span>
              </div>
            </div>
          </div>
          <div className="mt-4 p-3 bg-blue-900 rounded-lg border border-blue-700">
            <p className="text-blue-100 text-sm">
              <span className="font-bold">📊 INSIGHT:</span> Elevated stress during exam periods. Recommend: Extended counseling hours, academic support workshops
            </p>
          </div>
        </div>

        {/* Financial Insights */}
        <div className="bg-slate-800 rounded-lg p-6 border border-slate-700 shadow-xl">
          <h2 className="text-xl font-bold text-white mb-4">💰 Financial Questions Pulse</h2>
          <div className="space-y-3">
            {analyticsData.feeQuestions.map((question, i) => (
              <div key={i} className="flex items-center justify-between p-3 bg-slate-700 rounded-lg">
                <div>
                  <p className="font-semibold text-white">{question.topic}</p>
                  <p className="text-xs text-slate-400">{question.count} inquiries this month</p>
                </div>
                <div className="flex items-center gap-2">
                  <div className="w-32 bg-slate-600 rounded-full h-3">
                    <div
                      className="h-3 rounded-full bg-blue-500"
                      style={{ width: `${(question.count / analyticsData.feeQuestions[0].count) * 100}%` }}
                    />
                  </div>
                  <span className="text-white font-bold w-8">{question.count}</span>
                </div>
              </div>
            ))}
          </div>
          <div className="mt-4 p-3 bg-yellow-900 rounded-lg border border-yellow-700">
            <p className="text-yellow-100 text-sm">
              <span className="font-bold">💡 RECOMMENDATION:</span> Implement automated fee payment reminders and flexible installment plans
            </p>
          </div>
        </div>

        {/* Report Generator */}
        <button
          onClick={generateSenateBrief}
          className="w-full py-4 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white rounded-lg font-bold text-lg shadow-lg transition transform hover:scale-105"
        >
          📄 Generate Weekly Brief for Senate
        </button>
      </div>
    </div>
  );

  // ============= RENDER: ADMIN AUTH MODAL =============
  const renderAdminAuth = () => (
    <div className="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50">
      <div className="bg-white rounded-lg p-6 shadow-2xl max-w-sm w-full mx-4">
        <h2 className="text-2xl font-bold text-slate-900 mb-2">🔐 Admin Access</h2>
        <p className="text-sm text-slate-600 mb-4">Enter the administrator password</p>
        <div className="space-y-3">
          <input
            type="password"
            value={adminPassword}
            onChange={(e) => setAdminPassword(e.target.value)}
            onKeyPress={(e) => e.key === 'Enter' && handleAdminLogin()}
            placeholder="Enter password"
            className="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:outline-none"
            autoFocus
          />
          {adminPasswordError && (
            <p className="text-sm text-red-600 font-semibold">{adminPasswordError}</p>
          )}
        </div>
        <div className="flex gap-2 mt-4">
          <button
            onClick={() => {
              setShowAdminAuth(false);
              setAdminPassword('');
              setAdminPasswordError('');
            }}
            className="flex-1 px-4 py-2 bg-slate-200 text-slate-900 rounded-lg hover:bg-slate-300 font-semibold"
          >
            Cancel
          </button>
          <button
            onClick={handleAdminLogin}
            className="flex-1 px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 font-semibold"
          >
            Login
          </button>
        </div>
      </div>
    </div>
  );
  const renderLibraryTab = () => (
    <div className="flex flex-col h-full">
      {/* Messages */}
      <div className="flex-1 overflow-y-auto p-4 space-y-4">
        {libraryMessages.map((msg, i) => (
          <div key={i} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
            <div className={`max-w-xs p-3 rounded-lg ${msg.role === 'user' ? 'bg-blue-500 text-white' : 'bg-slate-200 text-slate-900'}`}>
              {msg.type === 'library' ? (
                <div className="space-y-3">
                  <h3 className="font-bold">{msg.book}</h3>
                  {msg.targetedPillars && (
                    <div className="bg-blue-50 p-3 rounded border-l-2 border-blue-500">
                      <p className="text-xs font-bold text-blue-900 mb-2">📌 3-PILLAR SUMMARY:</p>
                      {msg.targetedPillars.map((pillar, idx) => (
                        <div key={idx} className="text-xs text-slate-700 mb-1">
                          <span className="font-bold text-blue-800">{pillar.pillar}:</span> {pillar.focus}
                        </div>
                      ))}
                    </div>
                  )}
                  {msg.sections.map((sec, j) => (
                    <div key={j}>
                      <p className="font-semibold text-sm">{sec.title}</p>
                      {sec.content && <p className="text-sm">{sec.content}</p>}
                      {sec.items && <ul className="text-sm list-disc ml-4">{sec.items.map((item, k) => <li key={k}>{item}</li>)}</ul>}
                    </div>
                  ))}
                  {msg.role === 'assistant' && (
                    <button
                      onClick={() => speakMessage(msg.book + '. ' + msg.sections.map(s => s.title + ': ' + (s.content || '')).join('. '))}
                      className="mt-2 bg-blue-600 text-white text-xs px-2 py-1 rounded hover:bg-blue-700"
                      disabled={isSpeaking}
                    >
                      {isSpeaking ? '🔊 Speaking...' : '🔊 Listen'}
                    </button>
                  )}
                </div>
              ) : (
                <div>
                  <p>{msg.text}</p>
                  {msg.role === 'assistant' && (
                    <button
                      onClick={() => speakMessage(msg.text)}
                      className="mt-2 bg-blue-600 text-white text-xs px-2 py-1 rounded hover:bg-blue-700"
                      disabled={isSpeaking}
                    >
                      {isSpeaking ? '🔊 Speaking...' : '🔊 Listen'}
                    </button>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      {/* Input */}
      <div className="p-4 border-t border-slate-200 bg-white flex gap-2 items-center">
        {voiceSupported && (
          <button
            onClick={isListening ? stopVoiceListening : startVoiceListening}
            className={`p-2 rounded-lg transition-all ${isListening ? 'bg-red-500 animate-pulse' : 'bg-slate-200'} hover:opacity-80`}
            title={isListening ? 'Stop listening...' : 'Click to start speaking'}
          >
            {isListening ? '🛑' : '🎤'}
          </button>
        )}
        <input
          type="text"
          value={libraryInput}
          onChange={(e) => setLibraryInput(e.target.value)}
          onKeyPress={(e) => e.key === 'Enter' && handleLibrarySend()}
          placeholder={isListening ? 'Listening... speak now' : 'Ask about a topic...'}
          className="flex-1 px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button onClick={handleLibrarySend} className="bg-blue-500 text-white p-2 rounded-lg hover:bg-blue-600">
          <SendIcon />
        </button>
      </div>
    </div>
  );

  const renderWelfareTab = () => (
    <div className="flex flex-col h-full">
      {/* Sub-tabs */}
      <div className="flex gap-2 p-2 bg-slate-100 border-b border-slate-200 overflow-x-auto">
        {[
          { id: 'counseling', label: '💚 Counseling' },
          { id: 'medical', label: '⚕️ Medical' },
          { id: 'hostels', label: '🏠 Hostels' },
          { id: 'career', label: '💼 Career' },
          { id: 'campus', label: '🗺️ Campus' }
        ].map(tab => (
          <button
            key={tab.id}
            onClick={() => setWelfareSubTab(tab.id)}
            className={`px-3 py-2 rounded text-sm font-semibold whitespace-nowrap ${welfareSubTab === tab.id ? 'bg-blue-500 text-white' : 'bg-white text-slate-700'}`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      {/* Content */}
      <div className="flex-1 overflow-y-auto p-4">
        {welfareSubTab === 'counseling' && (
          <div className="space-y-4">
            {/* SEKU Contacts */}
            <div className="bg-blue-50 p-4 rounded-lg border border-blue-200">
              <h3 className="font-bold text-slate-900 mb-3">🤝 SEKU Counseling Contacts</h3>
              <div className="space-y-3">
                <div className="p-3 bg-white rounded border-l-4 border-blue-500">
                  <p className="font-semibold text-slate-900">{SEKU_DATA.welfare.dean.name}</p>
                  <p className="text-xs text-slate-600">{SEKU_DATA.welfare.dean.title}</p>
                  <p className="text-xs text-slate-600">📍 {SEKU_DATA.welfare.dean.office}</p>
                  <p className="text-sm text-blue-600 font-semibold mt-1">📞 {SEKU_DATA.welfare.dean.phone}</p>
                </div>
                <div className="p-3 bg-white rounded border-l-4 border-green-500">
                  <p className="font-semibold text-slate-900">{SEKU_DATA.welfare.counselor.name}</p>
                  <p className="text-xs text-slate-600">{SEKU_DATA.welfare.counselor.title}</p>
                  <p className="text-xs text-slate-600">📍 {SEKU_DATA.welfare.counselor.office}</p>
                  <p className="text-sm text-green-600 font-semibold mt-1">📞 {SEKU_DATA.welfare.counselor.phone}</p>
                </div>
              </div>
            </div>

            {showCrisisAlert && (
              <div className="p-4 bg-red-100 border-l-4 border-red-500 rounded">
                <p className="text-red-800 font-bold">🚨 Crisis Protocol Activated</p>
                <p className="text-red-700 text-sm">If you're in immediate danger, call emergency services or visit the health center immediately.</p>
                <p className="text-red-700 text-sm mt-2">Contact: {SEKU_DATA.welfare.counselor.phone}</p>
              </div>
            )}
            <div className="space-y-2 max-h-48 overflow-y-auto">
              {counselingMessages.map((msg, i) => (
                <div key={i} className={`p-3 rounded ${msg.role === 'user' ? 'bg-blue-100 text-slate-900' : 'bg-slate-200'}`}>
                  {msg.text}
                </div>
              ))}
            </div>
          </div>
        )}

        {welfareSubTab === 'medical' && (
          <div className="space-y-4">
            <textarea
              value={medicalSymptoms}
              onChange={(e) => setMedicalSymptoms(e.target.value)}
              placeholder="Describe your symptoms..."
              className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500"
              rows="4"
            />
            <button onClick={handleSmartTriage} className="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 font-semibold">
              Get Triage Recommendation
            </button>
            {triageResult && (
              <div className="p-4 bg-blue-50 border border-blue-200 rounded">
                <p className="font-semibold text-slate-900">Recommendation:</p>
                <p className="text-slate-700 mt-2">{triageResult.recommendation}</p>
              </div>
            )}
          </div>
        )}

        {welfareSubTab === 'hostels' && (
          <div className="space-y-4">
            {/* Hostel Selection - All 6 Hostels */}
            <div>
              <label className="block text-sm font-semibold text-slate-700 mb-2">Select Your Hostel</label>
              <select
                value={selectedHostel}
                onChange={(e) => setSelectedHostel(e.target.value)}
                className="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500"
              >
                {/* Boys Hostels */}
                <optgroup label="👨 Boys Hostels">
                  {SEKU_DATA.hostels.boys.map(hostel => (
                    <option key={hostel.name} value={hostel.name}>
                      {hostel.name} ({hostel.rooms})
                    </option>
                  ))}
                </optgroup>
                {/* Girls Hostels */}
                <optgroup label="👩 Girls Hostels">
                  {SEKU_DATA.hostels.girls.map(hostel => (
                    <option key={hostel.name} value={hostel.name}>
                      {hostel.name} ({hostel.rooms})
                    </option>
                  ))}
                </optgroup>
              </select>
            </div>

            {/* Issue Description */}
            <div>
              <label className="block text-sm font-semibold text-slate-700 mb-2">Report an Issue</label>
              <textarea
                value={hostelIssue}
                onChange={(e) => setHostelIssue(e.target.value)}
                placeholder="Broken window, leaky tap, electrical issue, etc..."
                className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500"
                rows="3"
              />
            </div>
            <button onClick={handleCreateHostelTicket} className="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 font-semibold">
              Report Maintenance Issue
            </button>

            {hostelTickets.length > 0 && (
              <div className="mt-6">
                <h3 className="font-bold text-slate-900 mb-2">📋 Your Tickets:</h3>
                {hostelTickets.map(ticket => (
                  <div key={ticket.id} className="p-3 bg-slate-100 rounded-lg mb-2 border-l-4 border-blue-500">
                    <p className="font-semibold">{ticket.hostel}</p>
                    <p className="text-sm text-slate-700">{ticket.issue}</p>
                    <p className="text-xs text-slate-600 mt-1">Status: <span className="font-semibold text-blue-600">{ticket.status}</span></p>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {welfareSubTab === 'career' && (
          <div className="space-y-4">
            <div className="bg-blue-50 p-4 rounded-lg border border-blue-200">
              <h3 className="font-bold text-slate-900 mb-2">📝 NITA Attachment Logbook</h3>
              <p className="text-sm text-slate-700">Engineering & Business Students - Draft your daily logbook entries with AI assistance</p>
            </div>
            <textarea
              value={logbookEntry}
              onChange={(e) => setLogbookEntry(e.target.value)}
              placeholder="Date: [Date] | Tasks: [What did you do?] | Skills: [What did you learn?] | Challenges: [What was difficult?]"
              className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500"
              rows="5"
            />
            <button onClick={handleLogbookAssist} className="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 font-semibold">
              Get AI Writing Assistance
            </button>
            {logbookAIResponse && (
              <div className="p-4 bg-blue-50 border border-blue-200 rounded space-y-3">
                <div>
                  <p className="text-sm font-semibold text-slate-700">📝 Your Entry:</p>
                  <p className="text-sm text-slate-600 mt-1">{logbookAIResponse.originalEntry}</p>
                </div>
                <div>
                  <p className="text-sm font-semibold text-slate-700">✨ Improved Version:</p>
                  <p className="text-sm text-slate-600 mt-1">{logbookAIResponse.improvedVersion}</p>
                </div>
                <div>
                  <p className="text-sm font-semibold text-slate-700">💡 Feedback:</p>
                  <p className="text-sm text-slate-600 mt-1">{logbookAIResponse.feedback}</p>
                </div>
              </div>
            )}
          </div>
        )}
        {welfareSubTab === 'campus' && (
          <div className="space-y-4">
            <h3 className="font-bold text-slate-900 text-lg">🗺️ SEKU Campus Guide</h3>
            
            {/* Tuition Block 1 */}
            <div>
              <h4 className="font-semibold text-slate-900 mb-2 text-blue-600">📍 {SEKU_DATA.campus.tuitionBlock1.name}</h4>
              {SEKU_DATA.campus.tuitionBlock1.buildings.map((building, i) => (
                <div key={i} className="p-3 bg-blue-50 rounded-lg mb-2 border-l-4 border-blue-500">
                  <p className="font-semibold text-slate-900">{building.name}</p>
                  <p className="text-sm text-slate-700">Room: {building.room}</p>
                </div>
              ))}
            </div>

            {/* Tuition Block 2 */}
            <div>
              <h4 className="font-semibold text-slate-900 mb-2 text-purple-600">📍 {SEKU_DATA.campus.tuitionBlock2.name}</h4>
              {SEKU_DATA.campus.tuitionBlock2.buildings.map((building, i) => (
                <div key={i} className="p-3 bg-purple-50 rounded-lg mb-2 border-l-4 border-purple-500">
                  <p className="font-semibold text-slate-900">{building.name}</p>
                  <p className="text-sm text-slate-700">Room: {building.room}</p>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Input for Counseling */}
      {welfareSubTab === 'counseling' && (
        <div className="p-4 border-t border-slate-200 bg-white flex gap-2">
          <input
            type="text"
            value={counselingInput}
            onChange={(e) => setCounselingInput(e.target.value)}
            onKeyPress={(e) => e.key === 'Enter' && handleCounselingSend()}
            placeholder="Share your thoughts..."
            className="flex-1 px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500"
          />
          <button onClick={handleCounselingSend} className="bg-blue-500 text-white p-2 rounded-lg hover:bg-blue-600">
            <SendIcon />
          </button>
        </div>
      )}
    </div>
  );

  // ============= MAIN RETURN =============
  return (
    <div className="flex flex-col h-screen bg-gradient-to-b from-slate-50 to-slate-100 font-sans">
      <SplashScreen isVisible={showSplash} onFinish={() => setShowSplash(false)} />

      {/* Admin Auth Modal */}
      {showAdminAuth && renderAdminAuth()}

      {/* Admin Dashboard */}
      {isAdminAuthenticated ? (
        renderAdminDashboard()
      ) : (
        <>
          {/* Header with Hidden Logo Click Counter */}
          <header
            onClick={handleLogoClick}
            className="bg-white border-b border-slate-200 p-4 shadow-sm cursor-pointer hover:bg-slate-50 transition"
          >
            <h1 className="text-xl font-bold text-slate-900">🎓 ElimuLink</h1>
            <p 
              className="text-xs text-slate-600 transition-opacity duration-500"
              style={{ opacity: welcomeFade }}
            >
              {welcomeMessages[welcomeMessageIndex]}
            </p>
          </header>

          {/* Content */}
          <div className="flex-1 overflow-hidden">
            {activeTab === 'library' && renderLibraryTab()}
            {activeTab === 'welfare' && renderWelfareTab()}
            {activeTab === 'services' && renderStudentServicesTab()}
            {activeTab === 'graduation' && renderGraduationAuditTab()}
            {activeTab === 'career' && renderCareerBridgeTab()}
          </div>

          {/* HIDDEN NAVIGATION - Zero-Click Stealth UI */}
          {/* Bottom Navigation is hidden - Smart routing handles everything */}
        </>
      )}
    </div>
  );
};

export default App;
