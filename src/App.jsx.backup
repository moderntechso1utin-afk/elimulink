  const handleAdminLogout = () => {
    setIsAdminAuthenticated(false);
    setActiveTab('library');
  };

  // ============= GRADUATION CHECKLIST HANDLERS =============
  const toggleChecklistItem = (id) => {
    setGraduationChecklist(prev =>
      prev.map(item => item.id === id ? { ...item, completed: !item.completed } : item)
    );
  };

  const getGraduationProgress = () => {
    const completed = graduationChecklist.filter(item => item.completed).length;
    return Math.round((completed / graduationChecklist.length) * 100);
  };

  // ============= SMART ROUTING: AUTO-CATEGORIZE MESSAGES =============
  const detectMessageCategory = (text) => {
    const lowerText = text.toLowerCase();
    
    // HOSTEL KEYWORDS
    if (lowerText.match(/water|leaks?|broken|tap|window|electrical|maintenance|room|hostel|dorm|plumbing|shower|toilet|bed|furniture|noise|heating|cooling/i)) {
      return 'hostel'; // But we'll use 'welfare' with hostel subtab
    }
    
    // LIBRARY/ACADEMIC KEYWORDS
    if (lowerText.match(/book|library|notes|study|exam|chapter|reading|textbook|pdf|assignment|homework|research|draft|essay|lecture|course material/i)) {
      return 'library';
    }
    
    // WELFARE/COUNSELING KEYWORDS
    if (lowerText.match(/stress|anxious|depression|worried|sad|counseling|mental|health|doctor|muoki|dean|sedina|therapy|support|pressure|overwhelmed|crisis|suicide|harm/i)) {
      return 'welfare';
    }
    
    // SERVICES/TRANSPORT KEYWORDS
    if (lowerText.match(/paybill|shuttle|transport|money|fee|payment|m-pesa|bus|transport|airport|town|shopping|shop|mess|food|dining/i)) {
      return 'services';
    }
    
    // CAREER/LOGBOOK KEYWORDS
    if (lowerText.match(/nita|logbook|attachment|career|job|internship|engineering|business|skills|experience|company|workplace/i)) {
      return 'career';
    }
    
    // GRADUATION KEYWORDS
    if (lowerText.match(/graduation|graduate|clearance|audit|checklist|books return|finance|department|library certificate|hostel deposit/i)) {
      return 'graduation';
    }
    
    return 'library'; // Default
  };

  // ============= VOICE INTERACTION HANDLERS =============
  const startVoiceListening = () => {
    if (!voiceSupported || !recognitionRef.current) return;

    setIsListening(true);
    let transcript = '';

    recognitionRef.current.onstart = () => {
      setIsListening(true);
    };

    recognitionRef.current.onresult = (event) => {
      for (let i = event.resultIndex; i < event.results.length; i++) {
        transcript += event.results[i][0].transcript;
      }
    };

    recognitionRef.current.onend = () => {
      setIsListening(false);
      if (transcript.trim()) {
        setLibraryInput(transcript);
        // Auto-send after speech recognition completes
        setTimeout(() => {
          // Trigger send after a brief delay
          const temp = transcript;
          handleLibrarySend();
        }, 100);
      }
    };

    recognitionRef.current.onerror = (event) => {
      console.error('Speech recognition error:', event.error);
      setIsListening(false);
    };

    recognitionRef.current.start();
  };

  const stopVoiceListening = () => {
    if (recognitionRef.current) {
      recognitionRef.current.stop();
      setIsListening(false);
    }
  };

  // Text-to-Speech: Read AI response out loud
  const speakMessage = (text) => {
    if (!synthRef.current) return;

    // Cancel any ongoing speech
    synthRef.current.cancel();

    const utterance = new SpeechSynthesisUtterance(text);
    utterance.rate = 1;
    utterance.pitch = 1;
    utterance.volume = 1;

    utterance.onstart = () => setIsSpeaking(true);
    utterance.onend = () => setIsSpeaking(false);
    utterance.onerror = () => setIsSpeaking(false);

    synthRef.current.speak(utterance);
  };

  // ============= IMAGE & VIDEO GENERATION HANDLERS =============
  const generateImage = async (prompt) => {
    setIsGeneratingImage(true);
    try {
      // For now, we'll simulate image generation
      // In production, this would call Google's Imagen-4 API
      // Example: https://cloud.google.com/vertex-ai/generative-ai/docs/model-garden/image-generation-api

      // Simulate API call delay
      await new Promise(resolve => setTimeout(resolve, 2000));

      // Create a placeholder image using canvas or placeholder service
      const placeholderImage = `https://via.placeholder.com/400x300?text=${encodeURIComponent(prompt.substring(0, 30))}`;

      setGeneratedImages(prev => ({
        ...prev,
        [prompt]: placeholderImage
      }));

      return placeholderImage;
    } catch (error) {
      console.error('Image generation error:', error);
    } finally {
      setIsGeneratingImage(false);
    }
  };

  const generateVideo = async (prompt) => {
    setIsGeneratingVideo(true);
    try {
      // Simulate video generation
      await new Promise(resolve => setTimeout(resolve, 3000));
      // In production, this would call a video generation API
      // For now, return a placeholder
      return { status: 'generating', prompt, duration: 30 };
    } catch (error) {
      console.error('Video generation error:', error);
    } finally {
      setIsGeneratingVideo(false);
    }
  };

  // ============= DUAL-BRAIN RESEARCH: INTERNAL + EXTERNAL QUERIES =============
  const performDualBrainSearch = async (query) => {
    // Determine if this is an external topic (places, events, general knowledge)
    const externalKeywords = ['kampala', 'uganda', 'nairobi', 'kenya', 'town', 'city', 'world', 'weather', 'news', 'current'];
    const isExternalQuery = externalKeywords.some(kw => query.toLowerCase().includes(kw));

    let response = '';

    if (isExternalQuery) {
      // Use Google Search grounding for external queries
      response = `🌍 **Research Mode: External + Internal**\n\n`;
      response += `📍 **Real-World Data** (via Google Search):\nSearching for "${query}" across global sources...\n\n`;
      response += `For location/travel queries, I would use:\n- Google Maps API for locations\n- Weather services for climate data\n- Current events data\n\n`;
      response += `🏫 **SEKU-Specific Data**:\nCombining with campus information from our institutional database.\n`;
      response += `\nNote: For production deployment, integrate Google Search API with grounding tools for real-time accuracy.`;
    } else {
      // Internal SEKU data
      response = `🏫 **Internal SEKU Database Query**\n\nSearching our institutional knowledge base for: "${query}"`;
    }

    return response;
  };

  // Apply smart routing when user sends a message
  const applySmartRouting = (messageText) => {
    const category = detectMessageCategory(messageText);
    
    // Map categories to actual tabs
    const categoryToTab = {
      'hostel': 'welfare',
      'library': 'library',
      'welfare': 'welfare',
      'services': 'services',
      'career': 'career',
      'graduation': 'graduation'
    };
    
    const targetTab = categoryToTab[category];
    if (targetTab) {
      setActiveTab(targetTab);
      
      // If it's a hostel question, also set the welfare subtab
      if (category === 'hostel') {
        setWelfareSubTab('hostels');
      }
    }
  };

  const generateSenateBrief = () => {
    const totalTickets = analyticsData.hostelRepairs.reduce((sum, h) => sum + h.tickets, 0);
    const avgStress = Math.round((analyticsData.studentSentiment.stress + analyticsData.studentSentiment.anxiety) / 2);
    const topFeeIssue = analyticsData.feeQuestions[0];
    const criticalHostels = analyticsData.hostelRepairs.filter(h => h.tickets > 10);

    const brief = `════════════════════════════════════════════════════════════════
SEKU EXECUTIVE INTELLIGENCE BRIEF
Generated: ${new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
Confidential - Vice-Chancellor Review Only
════════════════════════════════════════════════════════════════

📊 FACILITIES & INFRASTRUCTURE STATUS:

Total Maintenance Requests: ${totalTickets} across all 6 hostels
Critical Alert Count: ${criticalHostels.length} hostels

HOSTEL-BY-HOSTEL BREAKDOWN:
${analyticsData.hostelRepairs.map(h => `  • ${h.hostel}: ${h.tickets} tickets [${h.status}]`).join('\n')}

CRITICAL ISSUE: Turkana Hall with 15 maintenance requests
  - Priority repairs: Electrical systems, plumbing, structural leaks
  - Estimated cost: KES 2.8M
  - Timeline recommendation: 3 weeks

ACTION REQUIRED: Allocate emergency maintenance budget for immediate repairs

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

💭 STUDENT WELLNESS & COUNSELING PULSE:

Current Emotional Metrics:
  • Stress Level: ${analyticsData.studentSentiment.stress}% (${analyticsData.studentSentiment.stress > 60 ? 'ELEVATED' : 'MODERATE'})
  • Anxiety Index: ${analyticsData.studentSentiment.anxiety}% (${analyticsData.studentSentiment.anxiety > 50 ? 'HEIGHTENED' : 'NORMAL'})
  • Happiness Index: ${analyticsData.studentSentiment.happiness}% (Stable)

Key Findings:
  ✗ Elevated stress during exam periods
  ✗ Hostel condition concerns impacting wellbeing
  ✗ Financial pressure contributing to anxiety
  ✓ Counseling services well-utilized (+34% uptake)

RECOMMENDATION: Enhance mental health support during peak periods

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

💰 FINANCIAL QUESTIONS & STUDENT FEEDBACK:

Top 5 Student Concerns:
${analyticsData.feeQuestions.slice(0, 5).map((q, i) => `  ${i + 1}. "${q.topic}" - ${q.count} inquiries`).join('\n')}

Key Issues:
  • Payment deadline clarity needed
  • Penalty and late fee concerns
  • Scholarship status transparency
  • Financial aid processes unclear

STRATEGIC RECOMMENDATIONS:
  1. Implement automated payment reminder system
  2. Create flexible installment payment plans
  3. Publish fee schedules with penalty amnesty periods
  4. Establish scholarship information portal
