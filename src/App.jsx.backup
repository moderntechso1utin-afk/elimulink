// ============= LIBRARY MODULE WITH TARGETED EXTRACTION =============
const libraryModule = {
  books: {
    'data-structures': {
      title: 'Data Structures & Algorithms',
      author: 'Mark Allen Weiss',
      summary: 'A comprehensive guide to essential data structures and algorithm design patterns.',
      keyTopics: ['Arrays', 'Linked Lists', 'Trees', 'Sorting', 'Graphs'],
      targetedPillars: [
        { pillar: 'Structure', focus: 'How data is organized (Arrays vs Trees)' },
        { pillar: 'Operations', focus: 'Time complexity & access patterns (O(n) vs O(1))' },
        { pillar: 'Application', focus: 'When to use each structure (Hashtable for lookups)' }
      ],
      realWorldExamples: [
        'Facebook uses Graph data structures to represent friend connections',
        'Google Maps uses Dijkstra\'s Algorithm for shortest path routing',
        'Netflix uses Hash Tables for user recommendations lookup'
      ],
      pastExamQuestions: [
        'Explain the difference between BFS and DFS. When would you use each?',
        'Implement a binary search tree and write a function to find the kth smallest element.',
        'Given an array of integers, find all pairs that sum to a target value. Optimize for O(n) time.',
        'Explain why quicksort is faster than merge sort in practice despite same Big-O complexity.'
      ]
    },
    'law-of-tort': {
      title: 'Law of Tort',
      author: 'Legal Studies',
      summary: 'Understanding liability and civil remedies in tort law.',
      keyTopics: ['Negligence', 'Strict Liability', 'Defamation', 'Nuisance'],
      targetedPillars: [
        { pillar: 'Duty', focus: 'Establishing a duty of care (Neighbor principle)' },
        { pillar: 'Breach', focus: 'Proving breach of that duty (Standard of reasonable person)' },
        { pillar: 'Damage', focus: 'Quantifying compensable harm (General vs Special damages)' }
      ],
      realWorldExamples: [
        'Donoghue v Stevenson: Manufacturer liable for defective ginger beer bottle',
        'Caparo Test: Establishing duty of care in professional negligence cases',
        'Vicarious Liability: Employer responsible for employee negligent acts'
      ],
      pastExamQuestions: [
        'Apply the three pillars of tort to a case: A driver runs a red light and hits a pedestrian. Discuss duty, breach, and damages.',
        'Distinguish between negligence and strict liability with examples.',
        'A surgeon performs surgery without consent. What tort is committed? What damages apply?'
      ]
    },
    'software-engineering': {
      title: 'Software Engineering Principles',
      author: 'Andrew Hunt',
      summary: 'Practical software development practices and design principles for scalable applications.',
      keyTopics: ['Design Patterns', 'SOLID Principles', 'Testing', 'Refactoring', 'Documentation'],
      targetedPillars: [
        { pillar: 'Design', focus: 'Patterns & architecture (MVC, Singleton, Observer)' },
        { pillar: 'Quality', focus: 'Testing & code standards (TDD, linting, documentation)' },
        { pillar: 'Maintenance', focus: 'Refactoring & optimization (Debt reduction, performance)' }
      ],
      realWorldExamples: [
        'MVC pattern used by Django, Rails, and Laravel frameworks',
        'Singleton pattern used for database connections in production apps',
        'Observer pattern used in event-driven systems like message queues'
      ],
      pastExamQuestions: [
        'What is the difference between composition and inheritance? Give practical examples.',
        'Explain SOLID principles and how they improve code maintainability.',
        'Design a PaymentProcessor class. Which design patterns would you apply?',
        'How would you refactor a 500-line function? What metrics would you track?'
      ]
    },
    'web-development': {
      title: 'Modern Web Development',
      author: 'Kyle Simpson',
      summary: 'Building scalable, responsive web applications with modern JavaScript and frameworks.',
      keyTopics: ['React', 'State Management', 'APIs', 'Performance', 'Security'],
      targetedPillars: [
        { pillar: 'Frontend', focus: 'UI frameworks & component design (React, Vue, Angular)' },
        { pillar: 'Backend', focus: 'APIs & data management (REST, GraphQL, databases)' },
        { pillar: 'Deployment', focus: 'Performance & security (Caching, HTTPS, monitoring)' }
      ],
      realWorldExamples: [
        'React hooks used by Airbnb to manage component state elegantly',
        'Webpack bundling used by Spotify to optimize load times',
        'REST API design patterns used by Stripe for payment processing'
      ],
      pastExamQuestions: [
        'Build a todo app with React. Implement add, delete, and filter functionality.',
        'Explain virtual DOM. Why does React use it?',
        'How would you optimize a React component that re-renders unnecessarily?',
        'Design a REST API for an e-commerce platform. Include error handling.'
      ]
    }
  },

  searchBook: function(query) {
    const lowerQuery = query.toLowerCase();
    for (const [key, book] of Object.entries(this.books)) {
      if (lowerQuery.includes(key.replace('-', ' ')) || 
          lowerQuery.includes(book.title.toLowerCase()) ||
          book.keyTopics.some(topic => lowerQuery.includes(topic.toLowerCase()))) {
        return { found: true, bookKey: key, ...book };
      }
    }
    return { found: false };
  }
};

