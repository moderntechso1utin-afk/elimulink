const App = () => {
  // GLOBAL STATE
  const [activeTab, setActiveTab] = useState('library');
  const [showSplash, setShowSplash] = useState(true);

  // STEALTH UI STATE
  const [welcomeMessageIndex, setWelcomeMessageIndex] = useState(0);
  const [welcomeFade, setWelcomeFade] = useState(1);

  // VOICE INTERACTION STATE
  const [isListening, setIsListening] = useState(false);
  const [isSpeaking, setIsSpeaking] = useState(false);
  const [voiceSupported, setVoiceSupported] = useState(false);
  const recognitionRef = React.useRef(null);
  const synthRef = React.useRef(null);

  // IMAGE & VIDEO GENERATION STATE
  const [isGeneratingImage, setIsGeneratingImage] = useState(false);
  const [isGeneratingVideo, setIsGeneratingVideo] = useState(false);
  const [generatedImages, setGeneratedImages] = useState({});

  // Initialize Speech APIs
  React.useEffect(() => {
    // Check Web Speech API support
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (SpeechRecognition) {
      setVoiceSupported(true);
      recognitionRef.current = new SpeechRecognition();
      recognitionRef.current.continuous = false;
      recognitionRef.current.interimResults = true;
      recognitionRef.current.lang = 'en-US';
    }

    // Speech Synthesis (always available)
    synthRef.current = window.speechSynthesis;
  }, []);

  const welcomeMessages = [
    '💚 Welcome to ElimuLink... Ask me about Library',
    '📚 Welcome to ElimuLink... Ask me about Books & Exams',
    '🏠 Welcome to ElimuLink... Ask me about Hostels',
    '💰 Welcome to ElimuLink... Ask me about Services & Transport',
    '💙 Welcome to ElimuLink... Ask me about Counseling & Wellness'
  ];

  // Auto-rotate welcome messages every 3 seconds
  React.useEffect(() => {
    const fadeInterval = setInterval(() => {
      setWelcomeFade(0);
      setTimeout(() => {
        setWelcomeMessageIndex(prev => (prev + 1) % welcomeMessages.length);
        setWelcomeFade(1);
      }, 500);
    }, 3000);
    return () => clearInterval(fadeInterval);
  }, []);

  // LIBRARY STATE
  const [libraryInput, setLibraryInput] = useState('');
  const [libraryMessages, setLibraryMessages] = useState([
    { role: 'ai', text: 'Welcome John! 📚 Ask me about any book or topic. I\'ll provide summaries, real-world examples, and past exam questions.', isWelcome: true }
  ]);
  const [showLibraryWelcome, setShowLibraryWelcome] = useState(true);

  // WELFARE STATE
  const [welfareSubTab, setWelfareSubTab] = useState('counseling'); // counseling, medical, hostels, career, payments, campus
  const [counselingMessages, setCounselingMessages] = useState([
    { role: 'ai', text: '💚 Welcome to Safe Space. This is a confidential counseling mode. Share what\'s on your mind.', isWelcome: true }
  ]);
  const [counselingInput, setCounselingInput] = useState('');
  const [showCrisisAlert, setShowCrisisAlert] = useState(false);

  const [medicalSymptoms, setMedicalSymptoms] = useState('');
  const [triageResult, setTriageResult] = useState(null);

  // HOSTEL STATE
  const [hostelGender, setHostelGender] = useState('boys');
  const [selectedHostel, setSelectedHostel] = useState('Elementaita');
  const [hostelIssue, setHostelIssue] = useState('');
  const [hostelTickets, setHostelTickets] = useState([]);

  const [logbookEntry, setLogbookEntry] = useState('');
  const [logbookAIResponse, setLogbookAIResponse] = useState(null);

  // STUDENT SERVICES STATE
  const [studentServicesSubTab, setStudentServicesSubTab] = useState('financial');
  const [graduationChecklist, setGraduationChecklist] = useState([
    { id: 1, item: 'Return all library books', completed: false },
    { id: 2, item: 'Clear outstanding finance balance', completed: false },
    { id: 3, item: 'Complete all department units', completed: false },
    { id: 4, item: 'Get department clearance signature', completed: false },
    { id: 5, item: 'Obtain library clearance certificate', completed: false },
    { id: 6, item: 'Pay all hostel deposits', completed: false },
    { id: 7, item: 'Submit final project/thesis', completed: false },
    { id: 8, item: 'Attend graduation orientation', completed: false }
  ]);

  // ADMIN STATE
  const [logoClickCount, setLogoClickCount] = useState(0);
  const [showAdminAuth, setShowAdminAuth] = useState(false);
  const [adminPassword, setAdminPassword] = useState('');
  const [isAdminAuthenticated, setIsAdminAuthenticated] = useState(false);
  const [adminPasswordError, setAdminPasswordError] = useState('');

  // Mock Analytics Data
  const [analyticsData] = useState({
    hostelRepairs: [
      { hostel: 'Turkana', tickets: 15, status: '🔴 Critical' },
      { hostel: 'Elementaita', tickets: 8, status: '🟡 Normal' },
      { hostel: 'Victoria', tickets: 5, status: '🟢 Good' },
      { hostel: 'Turkwel', tickets: 3, status: '🟢 Good' },
      { hostel: 'Yatta', tickets: 2, status: '🟢 Good' },
      { hostel: 'Baringo', tickets: 6, status: '🟡 Normal' }
    ],
    studentSentiment: {
      stress: 68, // percentage
      anxiety: 45,
      happiness: 72
    },
    feeQuestions: [
      { topic: 'Tuition Payment Deadlines', count: 32 },
      { topic: 'Mess Fee Refunds', count: 28 },
      { topic: 'Hostel Deposit Issues', count: 19 },
      { topic: 'Late Payment Penalties', count: 15 },
      { topic: 'Scholarship Status', count: 12 }
    ]
  });

  const studentData = {
    name: "John Doe",
    regNo: "SEKU/BIT/001/2024",
    room: "H12-205"
  };

  // ============= LIBRARY HANDLERS =============
  const handleLibrarySend = () => {
    if (!libraryInput.trim()) return;
    
    const userMsg = { role: 'user', text: libraryInput };
    setLibraryMessages(prev => [...prev, userMsg]);
    const query = libraryInput;
    
    // SMART ROUTING: Detect category and switch tabs
    applySmartRouting(query);

    // IMAGE GENERATION DETECTION
    const imageKeywords = ['generate image', 'create image', 'draw', 'picture', 'visual', 'diagram', 'sketch', 'show me a'];
    const shouldGenerateImage = imageKeywords.some(kw => query.toLowerCase().includes(kw));

    // VIDEO GENERATION DETECTION
    const videoKeywords = ['generate video', 'create video', 'video', 'show video', 'animate'];
    const shouldGenerateVideo = videoKeywords.some(kw => query.toLowerCase().includes(kw));

    // RESEARCH QUERY DETECTION
    const isResearchQuery = query.toLowerCase().includes('research') || query.toLowerCase().includes('kampala') || query.toLowerCase().includes('uganda');
    
    setLibraryInput('');
    setShowLibraryWelcome(false);

    setTimeout(async () => {
      let result = null;
      if (import.meta.env.VITE_GEMINI_API_KEY) {
        result = await geminiAPI.searchBook(query);
      }
      if (!result || !result.found) {
        result = libraryModule.searchBook(query);
      }

      let aiResponse;
      if (result && result.found) {
        aiResponse = {
          role: 'ai',
          type: 'library',
          book: result.title,
          targetedPillars: result.targetedPillars || [],
          sections: [
            { title: '📖 Summary', content: result.summary },
            { title: '🔑 Key Topics', content: result.keyTopics.join(' • ') },
            { title: '🌍 Real-World Examples', items: result.realWorldExamples },
            { title: '📝 Exam Questions', items: result.pastExamQuestions }
          ]
        };
      } else {
        aiResponse = {
          role: 'ai',
          text: '🤔 Try asking about "Data Structures", "Law of Tort", "Software Engineering", or "Web Development"'
        };
      }
      setLibraryMessages(prev => [...prev, aiResponse]);

      // TRIGGER IMAGE GENERATION
      if (shouldGenerateImage) {
        setTimeout(async () => {
          const imageUrl = await generateImage(query);
          if (imageUrl) {
            setLibraryMessages(prev => [...prev, {
              role: 'ai',
              text: `🎨 Generated image for: "${query}"\n\nNote: Using placeholder service. Production would use Imagen-4 API.`,
              image: imageUrl
            }]);
          }
        }, 500);
      }

      // TRIGGER VIDEO GENERATION
      if (shouldGenerateVideo) {
        setTimeout(async () => {
          const videoInfo = await generateVideo(query);
          if (videoInfo) {
            setLibraryMessages(prev => [...prev, {
              role: 'ai',
              text: `🎬 Video generation initiated for: "${query}"\n\n📺 Status: ${videoInfo.status}\n⏱️ Duration: ${videoInfo.duration}s\n\nNote: Using placeholder. Production would call video generation API.`
            }]);
          }
        }, 800);
      }

      // TRIGGER RESEARCH QUERY
      if (isResearchQuery) {
        setTimeout(async () => {
          const researchResponse = await performDualBrainSearch(query);
          setLibraryMessages(prev => [...prev, {
            role: 'ai',
            text: researchResponse
          }]);
        }, 1100);
      }
    }, 800);
  };

  // ============= WELFARE: COUNSELING HANDLERS =============
  const handleCounselingSend = () => {
    if (!counselingInput.trim()) return;

    const lowerInput = counselingInput.toLowerCase();
    
    // SMART ROUTING: Detect category and switch tabs if needed
    applySmartRouting(counselingInput);

    const hasCrisisKeywords = CRISIS_KEYWORDS.some(kw => lowerInput.includes(kw));
    const hasSensitiveKeywords = SENSITIVE_KEYWORDS.some(kw => lowerInput.includes(kw));

    if (hasCrisisKeywords) {
      setShowCrisisAlert(true);
    }

    const userMsg = { role: 'user', text: counselingInput };
    setCounselingMessages(prev => [...prev, userMsg]);
    setCounselingInput('');

    setTimeout(async () => {
      let aiResponse = '';

      if (hasCrisisKeywords) {
        // CRISIS PROTOCOL - IMMEDIATE SUPPORT
        aiResponse = `🚨 **CRISIS SUPPORT - Please Reach Out Now**\n\nI'm deeply concerned about what you've shared. You are not alone, and help is available immediately.\n\n**CONTACT IMMEDIATELY:**\n☎️ Dr. Albert Muoki (Counseling Dept)\nPhone: ${SEKU_DATA.welfare.counselor.phone}\nLocation: ${SEKU_DATA.welfare.counselor.office}\n\n📍 Dr. Sedina Misango (Dean of Students)  \nPhone: ${SEKU_DATA.welfare.dean.phone}\nLocation: ${SEKU_DATA.welfare.dean.office}\n\n**Emergency Services:** Call 999 or visit the nearest hospital\n\nThe university has 24/7 counseling support, trained professionals, and comprehensive crisis intervention services. You deserve professional care, and it's available to you right now.`;
      } else if (hasSensitiveKeywords) {
        // SENSITIVE TOPIC PROTOCOL
        let sensitiveResponse = `💙 **Thank you for trusting me with this sensitive topic.**\n\nI want you to know that the university provides complete, confidential support:\n\n**SPEAK WITH OUR COUNSELORS:**\n☎️ **Dr. Albert Muoki** (Counseling Dept)\nPhone: ${SEKU_DATA.welfare.counselor.phone}\n\n📍 **Dr. Sedina Misango** (Dean of Students)\nPhone: ${SEKU_DATA.welfare.dean.phone}\n\n`;

        if (lowerInput.includes('pregnancy') || lowerInput.includes('pregnant')) {
          sensitiveResponse += `**About Pregnancy Support:**\nThe university understands that unplanned pregnancies present significant challenges. Kenya's laws restrict abortion access, BUT SEKU provides:\n\n✓ Full medical examination and healthcare\n✓ Psychological counseling (100% confidential)\n✓ Social support and options counseling\n✓ Financial assistance for medical care\n✓ Academic accommodations if needed\n✓ Continuation of studies with support\n\nYou have options, and professionals are ready to help you navigate them safely.`;
        } else if (lowerInput.includes('abortion')) {
          sensitiveResponse += `**Legal & Health Context:**\nIn Kenya, abortion is restricted by law. However, SEKU's medical team:\n\n✓ Provides full pre- and post-care support\n✓ Ensures your physical and mental health is protected\n✓ Maintains complete confidentiality\n✓ Offers counseling throughout the process\n✓ Provides ongoing psychological support\n\nReach out to Dr. Muoki or Dr. Misango to discuss your specific situation and available resources.`;
        } else if (lowerInput.includes('depression') || lowerInput.includes('anxiety')) {
          sensitiveResponse += `**Mental Health Support Available:**\n✓ Counseling sessions (free & confidential)\n✓ Psychiatric evaluation if needed\n✓ Support groups and peer counseling\n✓ Academic accommodations\n✓ Crisis intervention 24/7\n\nWhat you're experiencing is treatable. Professional help makes a real difference.`;
        } else if (lowerInput.includes('abuse') || lowerInput.includes('assault')) {
          sensitiveResponse += `**Safety & Support:**\n✓ Immediate safety planning\n✓ Medical examination & treatment\n✓ Confidential counseling\n✓ Reporting support (your choice)\n✓ Legal assistance available\n✓ Emergency accommodation if needed\n\nYou are not alone, and this was not your fault. Professional support is available immediately.`;
        }

        aiResponse = sensitiveResponse;
      } else {
        // REGULAR COUNSELING - AI RESPONSE
        const counselingPrompt = `You are a compassionate university counselor for SEKU. The student says: "${lowerInput}". Provide a warm, helpful response that:
1. Validates their feelings with genuine empathy
2. Offers specific, actionable advice for their situation
3. References campus resources (counseling office, health center, academic support, peer support)
4. Suggests stress-management or wellness techniques
5. Encourages them to take next steps
6. IMPORTANT: Avoid generic phrases like "I'm here to listen" - provide specific, varied advice based on their unique situation

Keep responses practical, warm, and resource-rich. Every response should be different and tailored.`;

        aiResponse = await geminiAPI.searchBook(counselingPrompt) || `I hear you. The university has many resources to support you—counselors, health services, academic advisors, and peer support groups. What specific area would you like help with?`;
      }

      setCounselingMessages(prev => [...prev, { role: 'ai', text: aiResponse }]);
    }, 800);
  };

  // ============= WELFARE: MEDICAL HANDLERS =============
  const handleSmartTriage = async () => {
    if (!medicalSymptoms.trim()) return;

    if (import.meta.env.VITE_GEMINI_API_KEY) {
      const result = await geminiAPI.searchBook(`Medical triage: ${medicalSymptoms}`);
      setTriageResult({
        symptoms: medicalSymptoms,
        recommendation: result.found ? result.summary : 'Please visit the health center for proper examination.'
      });
    } else {
      setTriageResult({
        symptoms: medicalSymptoms,
        recommendation: '⚠️ Please visit the Health Center at Building A, 2nd Floor. Hours: 8 AM - 5 PM'
      });
    }
  };

  // ============= WELFARE: HOSTEL HANDLERS =============
  // ============= WELFARE: HOSTEL HANDLERS =============
  const handleCreateHostelTicket = () => {
    if (!hostelIssue.trim()) return;

    const newTicket = {
      id: Date.now(),
      hostel: selectedHostel,
      issue: hostelIssue,
      status: 'Open',
      createdAt: new Date().toLocaleDateString()
    };

    setHostelTickets(prev => [...prev, newTicket]);
    setHostelIssue('');
  };

  // ============= WELFARE: CAREER HANDLERS =============
  const handleLogbookAssist = async () => {
    if (!logbookEntry.trim()) return;

    const nitaPrompt = `NITA Attachment Logbook Entry (Engineering/Business).${logbookEntry}. Improve this entry with: Date, Tasks completed, Skills learned, Challenges faced, Solutions applied.`;

    if (import.meta.env.VITE_GEMINI_API_KEY) {
      const result = await geminiAPI.searchBook(nitaPrompt);
      setLogbookAIResponse({
        originalEntry: logbookEntry,
        improvedVersion: result.found ? result.summary : logbookEntry,
        feedback: 'NITA Format: Include attachment period, deliverables, and competencies gained.'
      });
    } else {
      setLogbookAIResponse({
        originalEntry: logbookEntry,
        improvedVersion: logbookEntry,
        feedback: 'NITA Logbook Tips: Daily entries, Technical skills, Challenges & Solutions, Supervisor sign-off.'
      });
